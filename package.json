{
  "name": "my-vsc-themes",
  "displayName": "Colin's VS Code Themes",
  "description": "A colorful VS Code theme hub with orange, seasonal, holiday, and gaming-inspired palettes.",
  "version": "1.3.0",
  "publisher": "ColinGamez",
  "license": "MIT",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#180602",
    "theme": "dark"
  },
  "pricing": "Free",
  "repository": {
    "type": "git",

{
  "name": "my-vsc-themes",
  "displayName": "Colin's VS Code Themes",
  "description": "A colorful VS Code theme hub with themes, file icons, variants, and theme-switching commands.",
  "version": "1.4.0",
  "publisher": "ColinGamez",
  "license": "MIT",
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:my-vsc-themes.applySeasonalTheme",
    "onCommand:my-vsc-themes.applyHolidayTheme",
    "onCommand:my-vsc-themes.pickGamingTheme",
    "onCommand:my-vsc-themes.pickThemeByPack",
    "onCommand:my-vsc-themes.enableLightDarkAutoSwitch",
    "onCommand:my-vsc-themes.enableMonthlyAutoTheme",
    "onCommand:my-vsc-themes.disableMonthlyAutoTheme"
  ],
  "extensionKind": [
    "ui"
  ],
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#180602",
    "theme": "dark"
  },
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/ColinGamez/My-VSC-Themes.git"
  },
  "homepage": "https://github.com/ColinGamez/My-VSC-Themes#readme",
  "bugs": {
    "url": "https://github.com/ColinGamez/My-VSC-Themes/issues"
  },
  "scripts": {
    "build": "npm run build:icon && npm run build:no-italics && npm run build:variants && npm run build:extras && npm run build:file-icons && npm run build:previews && npm run build:sampler",
    "build:icon": "node scripts/build-icon.mjs",
    "build:no-italics": "node scripts/build-no-italics.mjs",
    "build:variants": "node scripts/build-variants.mjs",
    "build:extras": "node scripts/build-extra-themes.mjs",
    "build:file-icons": "node scripts/build-file-icons.mjs",
    "build:previews": "node scripts/build-previews.mjs",
    "build:sampler": "node scripts/build-sampler.mjs",
    "check:themes": "node scripts/check-theme-quality.mjs"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "theme pack",
    "dark theme",
    "light theme",
    "orange",
    "color theme",
    "seasonal themes",
    "holiday themes",
    "gaming themes",
    "halloween",
    "retro",
    "cyberpunk",
    "file icons",
    "auto theme",
    "theme switcher"
  ],
  "contributes": {
    "commands": [
      {
        "command": "my-vsc-themes.applySeasonalTheme",
        "title": "Apply Current Seasonal Theme",
        "category": "Colin's Themes"
      },
      {
        "command": "my-vsc-themes.applyHolidayTheme",
        "title": "Apply Current Holiday Theme",
        "category": "Colin's Themes"
      },
      {
        "command": "my-vsc-themes.pickGamingTheme",
        "title": "Pick Gaming Theme",
        "category": "Colin's Themes"
      },
      {
        "command": "my-vsc-themes.pickThemeByPack",
        "title": "Pick Theme By Pack",
        "category": "Colin's Themes"
      },
      {
        "command": "my-vsc-themes.enableLightDarkAutoSwitch",
        "title": "Enable Light/Dark Auto Switch",
        "category": "Colin's Themes"
      },
      {
        "command": "my-vsc-themes.enableMonthlyAutoTheme",
        "title": "Enable Startup Seasonal Auto Theme",
        "category": "Colin's Themes"
      },
      {
        "command": "my-vsc-themes.disableMonthlyAutoTheme",
        "title": "Disable Startup Seasonal Auto Theme",
        "category": "Colin's Themes"
      }
    ],
    "configuration": {
      "title": "Colin's VS Code Themes",
      "properties": {
        "myVscThemes.autoApplyOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Apply a Colin's Themes seasonal or holiday theme when VS Code starts."
        },
        "myVscThemes.autoMode": {
          "type": "string",
          "enum": [
            "seasonal",
            "holiday"
          ],
          "default": "seasonal",
          "description": "Controls which automatic theme rotation is used on startup."
        }
      }
    },
    "iconThemes": [
      {
        "id": "colins-color-icons",
        "label": "Colin's Color Icons",
        "path": "./fileicons/colins-color-icons-icon-theme.json"
      }
    ],

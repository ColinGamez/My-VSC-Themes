        "category": "Colin's Themes"
      },
      {
        "command": "my-vsc-themes.setReactorWorkspaceTheme",
        "title": "Set Theme Reactor Workspace Theme",
        "category": "Colin's Themes"
      }
    ],
    "configuration": {
      "title": "Colin's VS Code Themes",
      "properties": {
        "myVscThemes.autoApplyOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Apply a Colin's Themes seasonal or holiday theme when VS Code starts."
        },
        "myVscThemes.autoMode": {
          "type": "string",
          "enum": [
            "seasonal",
            "holiday"
          ],
          "default": "seasonal",
          "description": "Controls which automatic theme rotation is used on startup."
        },
        "myVscThemes.reactor.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Automatically apply Theme Reactor when VS Code starts and while VS Code is open."
        },
        "myVscThemes.reactor.mode": {
          "type": "string",
          "enum": [
            "hybrid",
            "timeOfDay",
            "seasonal",
            "holiday"
          ],
          "enumDescriptions": [
            "Use holiday themes in holiday months and time-of-day themes otherwise.",
            "Use the morning, day, evening, and night schedule.",
            "Use Spring Bloom, Summer Sunset, Autumn Ember, or Winter Aurora by month.",
            "Use holiday themes when available, with seasonal fallback."
          ],
          "default": "hybrid",
          "description": "Controls how Theme Reactor chooses a theme."
        },
        "myVscThemes.reactor.schedule": {
          "type": "object",
          "default": {
            "morning": "Spring Bloom",
            "day": "Peach Soda",
            "evening": "Summer Sunset",
            "night": "All Orange"
          },
          "additionalProperties": {
            "type": "string"
          },
          "description": "Theme Reactor time-of-day schedule. Supported keys: morning, day, evening, night."
        },
        "myVscThemes.reactor.favorites": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "All Orange",
            "All Orange High Contrast",
            "Summer Sunset",
            "Autumn Ember",
            "Winter Aurora",
            "Starfighter HUD"
          ],
          "description": "Themes used by Theme Reactor favorite and random commands."
        },
        "myVscThemes.reactor.workspaceTheme": {
          "type": "string",
          "default": "",
        "description": "Workspace-specific Theme Reactor override. Leave empty to use the normal Theme Reactor mode."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "colins-code-suite",

  "publisher": "ColinGamez",
  "license": "MIT",
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:my-vsc-themes.applySeasonalTheme",
    "onCommand:my-vsc-themes.applyHolidayTheme",
    "onCommand:my-vsc-themes.pickGamingTheme",
    "onCommand:my-vsc-themes.pickThemeByPack",
    "onCommand:my-vsc-themes.enableLightDarkAutoSwitch",
    "onCommand:my-vsc-themes.enableMonthlyAutoTheme",
    "onCommand:my-vsc-themes.disableMonthlyAutoTheme",
    "onCommand:my-vsc-themes.applyOrangePreset",
    "onCommand:my-vsc-themes.applyFocusPreset",
    "onCommand:my-vsc-themes.applyLightPreset",
    "onCommand:my-vsc-themes.applyGamingPreset",
    "onCommand:my-vsc-themes.enableThemeReactor",
    "onCommand:my-vsc-themes.disableThemeReactor",
    "onCommand:my-vsc-themes.applyThemeReactorNow",
    "onCommand:my-vsc-themes.pickReactorFavorite",
    "onCommand:my-vsc-themes.randomReactorFavorite",
    "onCommand:my-vsc-themes.configureReactorFavorites",
    "onCommand:my-vsc-themes.setReactorWorkspaceTheme",
    "onView:my-vsc-themes.commandCenter",
    "onCommand:my-vsc-themes.commandCenter.open",
    "onCommand:my-vsc-themes.commandCenter.refresh",
    "onCommand:my-vsc-themes.commandCenter.runBestScript",
    "onCommand:my-vsc-themes.commandCenter.openTerminal",
    "onCommand:my-vsc-themes.commandCenter.openRepository",
    "onCommand:my-vsc-themes.commandCenter.createMissingBasics",
    "onCommand:my-vsc-themes.readmeStudio.open"
  ],
  "extensionKind": [
    "ui"
  ],
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#180602",
    "theme": "dark"
  },
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/ColinGamez/My-VSC-Themes.git"
  },
  "homepage": "https://github.com/ColinGamez/My-VSC-Themes#readme",
  "bugs": {

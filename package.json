{
  "name": "my-vsc-themes",
  "displayName": "Colin's VS Code Themes",
  "description": "A small VS Code theme hub with colorful dark and light palettes.",
  "version": "1.0.0",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ColinGamez/My-VSC-Themes.git"
  },
  "homepage": "https://github.com/ColinGamez/My-VSC-Themes#readme",
  "bugs": {
    "url": "https://github.com/ColinGamez/My-VSC-Themes/issues"
  },
  "scripts": {
    "build": "npm run build:no-italics && npm run build:extras && npm run build:previews",
    "build:no-italics": "node scripts/build-no-italics.mjs",
    "build:extras": "node scripts/build-extra-themes.mjs",
    "build:previews": "node scripts/build-previews.mjs"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark theme",
    "orange",
    "color theme"
  ],
  "contributes": {
    "themes": [
      {
        "label": "All Orange",
        "uiTheme": "vs-dark",
        "path": "./themes/all-orange-color-theme.json"
      },
      {
        "label": "All Orange No Italics",
        "uiTheme": "vs-dark",
        "path": "./themes/all-orange-no-italics-color-theme.json"
      },
      {
        "label": "Neon Arcade",
        "uiTheme": "vs-dark",
        "path": "./themes/neon-arcade-color-theme.json"
      },
      {
        "label": "Matcha Grove",
        "uiTheme": "vs-dark",
        "path": "./themes/matcha-grove-color-theme.json"
      },
      {
        "label": "Peach Soda",
        "uiTheme": "vs",
        "path": "./themes/peach-soda-color-theme.json"
      },
      {
        "label": "Blue Raspberry",
        "uiTheme": "vs-dark",
        "path": "./themes/blue-raspberry-color-theme.json"
      },
      {
        "label": "Cherry Cola",
        "uiTheme": "vs-dark",
        "path": "./themes/cherry-cola-color-theme.json"
      },
      {
        "label": "Lavender Static",
        "uiTheme": "vs-dark",
        "path": "./themes/lavender-static-color-theme.json"
      },
      {
        "label": "Ocean Byte",
        "uiTheme": "vs-dark",
        "path": "./themes/ocean-byte-color-theme.json"
      },
      {
        "label": "Graphite Pop",
        "uiTheme": "vs-dark",
        "path": "./themes/graphite-pop-color-theme.json"
      },
      {
        "label": "Honey Terminal",
        "uiTheme": "vs",
        "path": "./themes/honey-terminal-color-theme.json"
      }
    ]
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}

{
  "name": "all-orange-theme",
  "displayName": "Colin's VS Code Themes",
  "description": "A small VS Code theme hub with orange, neon, matcha, and peach palettes.",
  "version": "0.1.0",
  "publisher": "local",
  "license": "MIT",
  "scripts": {
    "build": "npm run build:no-italics && npm run build:extras",
    "build:no-italics": "node scripts/build-no-italics.mjs",
    "build:extras": "node scripts/build-extra-themes.mjs"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark theme",
    "orange",
    "color theme"
  ],
  "contributes": {
    "themes": [
      {
        "label": "All Orange",
        "uiTheme": "vs-dark",
        "path": "./themes/all-orange-color-theme.json"
      },
      {
        "label": "All Orange No Italics",
        "uiTheme": "vs-dark",
        "path": "./themes/all-orange-no-italics-color-theme.json"
      },
      {
        "label": "Neon Arcade",
        "uiTheme": "vs-dark",
        "path": "./themes/neon-arcade-color-theme.json"
      },
      {
        "label": "Matcha Grove",
        "uiTheme": "vs-dark",
        "path": "./themes/matcha-grove-color-theme.json"
      },
      {
        "label": "Peach Soda",
        "uiTheme": "vs",
        "path": "./themes/peach-soda-color-theme.json"
      }
    ]
  }
}

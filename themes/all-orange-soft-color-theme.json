  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#d89a73",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#ffd59a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffd59a"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff9f68",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#ffd59a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#ffd59a"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#ffd59a"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#ffd59a"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#ffd59a"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff9f68"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ffd59a"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#ff9f68",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ffd59a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#ffd59a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#d89a73"
      }
    },
    {
      "scope": [
        "meta.structure.dictionary.json string.quoted.double.json",
        "support.type.property-name.json",
        "meta.object-literal.key",
        "variable.other.readwrite.alias.js",
        "variable.other.readwrite.alias.ts"
      ],
      "settings": {
        "foreground": "#ff9f68"
      }
    },
    {
      "scope": [
        "meta.structure.dictionary.value.json string.quoted.double.json",
        "string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#ffd59a"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss",
        "meta.property-name.css",
        "meta.property-name.scss"
      ],
      "settings": {
        "foreground": "#ff9f68"
      }
    },
    {
      "scope": [
        "meta.property-value.css",
        "meta.property-value.scss",
        "support.constant.property-value.css",
        "support.constant.property-value.scss",
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#ffd59a"
      }
    },
    {
      "scope": [
        "support.module",
        "support.type.object.module",
        "support.variable",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#ffc58d"
      }
    },
    {
      "scope": [
        "constant.other.symbol.ruby",
        "punctuation.definition.constant.ruby",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#ff9f68"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.vue",
        "entity.other.attribute-name.jsx",
        "entity.other.attribute-name.tsx",
        "support.type.property-name.vue"
      ],
      "settings": {
        "foreground": "#ffd59a"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#ff9f68"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#fff0d9",
        "background": "#9a4325"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#ffd59a",
    "class": "#ffd59a",
    "interface": "#ffd59a",
    "enum": "#ffd59a",
    "type": "#ffd59a",
    "typeParameter": "#ffd59a",
    "function": "#ffd59a",
    "method": "#ffd59a",
    "macro": "#ff9f68",
    "variable": "#ffd59a",
    "parameter": "#ffd59a",
    "property": "#ffd59a",
    "enumMember": "#ffd59a",
    "event": "#ff9f68",
    "operator": "#ff9f68",
    "keyword": {
      "foreground": "#ff9f68",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#d89a73",
      "fontStyle": "italic"
    },
    "string": "#ffd59a",
    "number": "#ffd59a",
    "regexp": "#ffd59a",
    "decorator": "#ff9f68"
  }
}

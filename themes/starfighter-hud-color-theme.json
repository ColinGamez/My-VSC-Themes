    "symbolIcon.variableForeground": "#e6f7ff",
    "symbolIcon.propertyForeground": "#7ee8fa"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5d7f99",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#a7f3d0"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#f9f871"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff9f1c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#00d7ff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#80bfff"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#e6f7ff"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#f9f871"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#7ee8fa"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff9f1c"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#7ee8fa"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#00d7ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#f9f871",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#80bfff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#050b16",
        "background": "#ff595e"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#80bfff",
    "class": "#80bfff",
    "interface": "#80bfff",
    "enum": "#f9f871",
    "type": "#80bfff",
    "typeParameter": "#f9f871",
    "function": "#00d7ff",
    "method": "#00d7ff",
    "macro": "#00d7ff",
    "variable": "#e6f7ff",
    "parameter": "#f9f871",
    "property": "#7ee8fa",
    "enumMember": "#f9f871",
    "event": "#ff9f1c",
    "operator": "#00d7ff",
    "keyword": {
      "foreground": "#ff9f1c",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#5d7f99",
      "fontStyle": "italic"
    },
    "string": "#a7f3d0",
    "number": "#f9f871",
    "regexp": "#80bfff",
    "decorator": "#ff9f1c"
  }
}

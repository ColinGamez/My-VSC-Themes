    "terminal.ansiWhite": "#d3fbff",
    "terminal.ansiBrightBlack": "#72aeb6",
    "terminal.ansiBrightRed": "#ff6b6b",
    "terminal.ansiBrightGreen": "#8df7d2",
    "terminal.ansiBrightYellow": "#ffcf70",
    "terminal.ansiBrightBlue": "#4aa3ff",
    "terminal.ansiBrightMagenta": "#4aa3ff",
    "terminal.ansiBrightCyan": "#35d0ba",
    "terminal.ansiBrightWhite": "#ffffff",
    "input.background": "#041417",
    "input.foreground": "#d3fbff",
    "input.border": "#16606c",
    "input.placeholderForeground": "#72aeb6",
    "inputOption.activeBackground": "#35d0ba22",
    "inputOption.activeBorder": "#35d0ba",
    "inputValidation.errorBackground": "#082229",
    "inputValidation.errorBorder": "#ff6b6b",
    "inputValidation.warningBackground": "#082229",
    "inputValidation.warningBorder": "#ffcf70",
    "inputValidation.infoBackground": "#082229",
    "inputValidation.infoBorder": "#35d0ba",
    "button.background": "#35d0ba",
    "button.foreground": "#041417",

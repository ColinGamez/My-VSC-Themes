    "gitDecoration.modifiedResourceForeground": "#ffcf70",
    "gitDecoration.deletedResourceForeground": "#ff6b6b",
    "gitDecoration.untrackedResourceForeground": "#8df7d2",
    "gitDecoration.ignoredResourceForeground": "#72aeb6",
    "gitDecoration.conflictingResourceForeground": "#4aa3ff",
    "diffEditor.insertedTextBackground": "#8df7d222",
    "diffEditor.removedTextBackground": "#ff6b6b22",
    "diffEditor.border": "#16606c",
    "peekView.border": "#35d0ba",
    "peekViewEditor.background": "#041417",
    "peekViewResult.background": "#061c22",
    "peekViewTitle.background": "#0d3540",
    "peekViewTitleLabel.foreground": "#d3fbff",
    "peekViewTitleDescription.foreground": "#72aeb6"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5d9299",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#8df7d2"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffcf70"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#35d0ba",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#4aa3ff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#9dd9ff"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#d3fbff"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#ffcf70"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#7ee8e0"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#35d0ba"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#7ee8e0"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#35d0ba",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ffcf70",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#9dd9ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#041417",
        "background": "#ff6b6b"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#9dd9ff",
    "class": "#9dd9ff",
    "interface": "#9dd9ff",
    "enum": "#ffcf70",
    "type": "#9dd9ff",
    "typeParameter": "#ffcf70",
    "function": "#4aa3ff",
    "method": "#4aa3ff",
    "macro": "#35d0ba",
    "variable": "#d3fbff",
    "parameter": "#ffcf70",
    "property": "#7ee8e0",
    "enumMember": "#ffcf70",
    "event": "#4aa3ff",
    "operator": "#35d0ba",
    "keyword": {
      "foreground": "#35d0ba",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#5d9299",
      "fontStyle": "italic"
    },
    "string": "#8df7d2",
    "number": "#ffcf70",
    "regexp": "#9dd9ff",
    "decorator": "#4aa3ff"
  }
}

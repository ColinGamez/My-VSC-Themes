    "notifications.foreground": "#d3fbff",
    "notifications.border": "#16606c",
    "notificationToast.border": "#16606c",
    "breadcrumb.background": "#041417",
    "breadcrumb.foreground": "#72aeb6",
    "breadcrumb.focusForeground": "#d3fbff",
    "breadcrumb.activeSelectionForeground": "#35d0ba",

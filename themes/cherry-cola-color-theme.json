    "editorGutter.addedBackground": "#c7d36f",
    "editorGutter.deletedBackground": "#ff304f",
    "minimap.background": "#140607",
    "minimap.selectionHighlight": "#ff4e5f70",
    "minimap.findMatchHighlight": "#ffd08a",
    "minimap.errorHighlight": "#ff304f",
    "minimap.warningHighlight": "#ffd08a",
    "statusBar.background": "#3a1215",
    "statusBar.foreground": "#ffe2d0",
    "statusBar.border": "#6e2529",
    "statusBar.debuggingBackground": "#ff4e5f",
    "statusBar.debuggingForeground": "#140607",
    "statusBar.noFolderBackground": "#1f0b0c",

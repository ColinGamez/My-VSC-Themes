    "terminal.ansiBrightBlack": "#bd7b71",
    "terminal.ansiBrightRed": "#ff304f",
    "terminal.ansiBrightGreen": "#c7d36f",
    "terminal.ansiBrightYellow": "#ffd08a",
    "terminal.ansiBrightBlue": "#ff8a65",
    "terminal.ansiBrightMagenta": "#d9995b",
    "terminal.ansiBrightCyan": "#ff4e5f",
    "terminal.ansiBrightWhite": "#ffffff",
    "input.background": "#140607",
    "input.foreground": "#ffe2d0",
    "input.border": "#6e2529",
    "input.placeholderForeground": "#bd7b71",
    "inputOption.activeBackground": "#ff4e5f22",
    "inputOption.activeBorder": "#ff4e5f",
    "inputValidation.errorBackground": "#1f0b0c",
    "inputValidation.errorBorder": "#ff304f",
    "inputValidation.warningBackground": "#1f0b0c",
    "inputValidation.warningBorder": "#ffd08a",
    "inputValidation.infoBackground": "#1f0b0c",
    "inputValidation.infoBorder": "#ff4e5f",
    "button.background": "#ff4e5f",
    "button.foreground": "#140607",
    "button.hoverBackground": "#ffd08a",
    "button.secondaryBackground": "#3a1215",
    "button.secondaryForeground": "#ffe2d0",
    "button.secondaryHoverBackground": "#6e2529",
    "dropdown.background": "#140607",
    "dropdown.foreground": "#ffe2d0",
    "dropdown.border": "#6e2529",
    "list.activeSelectionBackground": "#3a1215",
    "list.activeSelectionForeground": "#ffe2d0",
    "list.inactiveSelectionBackground": "#1f0b0c",
    "list.inactiveSelectionForeground": "#ffe2d0",
    "list.hoverBackground": "#1f0b0c",
    "list.highlightForeground": "#ff4e5f",
    "list.focusOutline": "#ff4e5f",
    "menu.background": "#1a0809",
    "menu.foreground": "#ffe2d0",
    "menu.selectionBackground": "#3a1215",
    "menu.selectionForeground": "#ffe2d0",
    "menu.separatorBackground": "#6e2529",

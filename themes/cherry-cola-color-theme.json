    "scrollbarSlider.activeBackground": "#ff4e5f88",
    "editorOverviewRuler.border": "#140607",
    "editorOverviewRuler.modifiedForeground": "#ffd08a",
    "editorOverviewRuler.addedForeground": "#c7d36f",
    "editorOverviewRuler.deletedForeground": "#ff304f",
    "editorOverviewRuler.errorForeground": "#ff304f",
    "editorOverviewRuler.warningForeground": "#ffd08a",
    "editorOverviewRuler.infoForeground": "#ff4e5f",
    "badge.background": "#ff4e5f",
    "badge.foreground": "#140607",
    "progressBar.background": "#ff4e5f",
    "notificationCenter.border": "#6e2529",
    "notificationCenterHeader.background": "#3a1215",
    "notificationCenterHeader.foreground": "#ffe2d0",
    "notifications.background": "#1a0809",
    "notifications.foreground": "#ffe2d0",
    "notifications.border": "#6e2529",
    "notificationToast.border": "#6e2529",
    "breadcrumb.background": "#140607",
    "breadcrumb.foreground": "#bd7b71",
    "breadcrumb.focusForeground": "#ffe2d0",
    "breadcrumb.activeSelectionForeground": "#ff4e5f",
    "gitDecoration.addedResourceForeground": "#c7d36f",
    "gitDecoration.modifiedResourceForeground": "#ffd08a",
    "gitDecoration.deletedResourceForeground": "#ff304f",
    "gitDecoration.untrackedResourceForeground": "#c7d36f",
    "gitDecoration.ignoredResourceForeground": "#bd7b71",
    "gitDecoration.conflictingResourceForeground": "#d9995b",
    "diffEditor.insertedTextBackground": "#c7d36f22",
    "diffEditor.removedTextBackground": "#ff304f22",
    "diffEditor.border": "#6e2529",
    "peekView.border": "#ff4e5f",
    "peekViewEditor.background": "#140607",
    "peekViewResult.background": "#1a0809",
    "peekViewTitle.background": "#3a1215",
    "peekViewTitleLabel.foreground": "#ffe2d0",
    "peekViewTitleDescription.foreground": "#bd7b71"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#a96860",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#ffd08a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#d9995b"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff4e5f",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#ff8a65"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#ffc1ad"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#ffe2d0"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#ffd08a"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#ff9e80"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff4e5f"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ff9e80"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#ff4e5f",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ffd08a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#ffc1ad",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#140607",
        "background": "#ff304f"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#ffc1ad",
    "class": "#ffc1ad",
    "interface": "#ffc1ad",
    "enum": "#d9995b",
    "type": "#ffc1ad",
    "typeParameter": "#ffd08a",
    "function": "#ff8a65",
    "method": "#ff8a65",
    "macro": "#ff4e5f",
    "variable": "#ffe2d0",
    "parameter": "#ffd08a",
    "property": "#ff9e80",
    "enumMember": "#d9995b",
    "event": "#d9995b",
    "operator": "#ff4e5f",
    "keyword": {
      "foreground": "#ff4e5f",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#a96860",
      "fontStyle": "italic"
    },
    "string": "#ffd08a",
    "number": "#d9995b",
    "regexp": "#ffc1ad",
    "decorator": "#d9995b"
  }
}

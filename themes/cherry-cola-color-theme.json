    "statusBarItem.remoteBackground": "#ff4e5f",
    "statusBarItem.remoteForeground": "#140607",
    "titleBar.activeBackground": "#1f0b0c",
    "titleBar.activeForeground": "#ffe2d0",
    "titleBar.inactiveBackground": "#1a0809",
    "titleBar.inactiveForeground": "#bd7b71",
    "titleBar.border": "#6e2529",
    "panel.background": "#1a0809",
    "panel.foreground": "#ffe2d0",
    "panel.border": "#6e2529",
    "panelTitle.activeForeground": "#ffe2d0",
    "panelTitle.inactiveForeground": "#bd7b71",
    "panelTitle.activeBorder": "#ff4e5f",
    "terminal.background": "#140607",
    "terminal.foreground": "#ffe2d0",
    "terminal.ansiBlack": "#140607",
    "terminal.ansiRed": "#ff304f",
    "terminal.ansiGreen": "#c7d36f",
    "terminal.ansiYellow": "#ffd08a",

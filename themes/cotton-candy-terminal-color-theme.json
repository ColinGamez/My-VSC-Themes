    "symbolIcon.propertyForeground": "#ffc2f0"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#818abc",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#b9fbc0"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#fff0a6"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff9de2",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#9adfff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#c8b6ff"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#f7eaff"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#fff0a6"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#ffc2f0"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff9de2"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ffc2f0"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#ff9de2",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#fff0a6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#c8b6ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#0d1024",
        "background": "#ff719a"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#c8b6ff",
    "class": "#c8b6ff",
    "interface": "#c8b6ff",
    "enum": "#fff0a6",
    "type": "#c8b6ff",
    "typeParameter": "#fff0a6",
    "function": "#9adfff",
    "method": "#9adfff",
    "macro": "#ff9de2",
    "variable": "#f7eaff",
    "parameter": "#fff0a6",
    "property": "#ffc2f0",
    "enumMember": "#fff0a6",
    "event": "#9adfff",
    "operator": "#ff9de2",
    "keyword": {
      "foreground": "#ff9de2",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#818abc",
      "fontStyle": "italic"
    },
    "string": "#b9fbc0",
    "number": "#fff0a6",
    "regexp": "#c8b6ff",
    "decorator": "#9adfff"
  }
}

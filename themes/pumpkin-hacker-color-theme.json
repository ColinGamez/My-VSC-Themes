  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9c6540",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#8cff66"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffc15a"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff8a1f",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#ffad45"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#ffd27a"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#ffd7a1"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#ffc15a"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#ffb86b"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff8a1f"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ffb86b"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#ff8a1f",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ffc15a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#ffd27a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#100804",
        "background": "#ff5d38"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#ffd27a",
    "class": "#ffd27a",
    "interface": "#ffd27a",
    "enum": "#ffc15a",
    "type": "#ffd27a",
    "typeParameter": "#ffc15a",
    "function": "#ffad45",
    "method": "#ffad45",
    "macro": "#ff8a1f",
    "variable": "#ffd7a1",
    "parameter": "#ffc15a",
    "property": "#ffb86b",
    "enumMember": "#ffc15a",
    "event": "#8cff66",
    "operator": "#ff8a1f",
    "keyword": {
      "foreground": "#ff8a1f",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#9c6540",
      "fontStyle": "italic"
    },
    "string": "#8cff66",
    "number": "#ffc15a",
    "regexp": "#ffd27a",
    "decorator": "#8cff66"
  }
}

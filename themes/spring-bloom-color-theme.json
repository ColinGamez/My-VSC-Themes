  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7b9863",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#4f9a56"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#c28512"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#cf4f8b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#2e9d8f"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#6c8fd8"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#24351c"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#9a6a00"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#668a32"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#cf4f8b"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#668a32"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#3f8f32",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#9a6a00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#6c8fd8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ffffff",
        "background": "#c2410c"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#6c8fd8",
    "class": "#6c8fd8",
    "interface": "#6c8fd8",
    "enum": "#c28512",
    "type": "#6c8fd8",
    "typeParameter": "#9a6a00",
    "function": "#2e9d8f",
    "method": "#2e9d8f",
    "macro": "#3f8f32",
    "variable": "#24351c",
    "parameter": "#9a6a00",
    "property": "#668a32",
    "enumMember": "#c28512",
    "event": "#c74b82",
    "operator": "#3f8f32",
    "keyword": {
      "foreground": "#cf4f8b",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#7b9863",
      "fontStyle": "italic"
    },
    "string": "#4f9a56",
    "number": "#c28512",
    "regexp": "#6c8fd8",
    "decorator": "#c74b82"
  }
}

  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#f08b57",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#ffdc8a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffdc8a"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff8a3d",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#ffdc8a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#ffdc8a"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#ffdc8a"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#ffdc8a"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#ffdc8a"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff8a3d"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ffdc8a"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#ff8a3d",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ffdc8a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#ffdc8a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#f08b57"
      }
    },
    {
      "scope": [
        "meta.structure.dictionary.json string.quoted.double.json",
        "support.type.property-name.json",
        "meta.object-literal.key",
        "variable.other.readwrite.alias.js",
        "variable.other.readwrite.alias.ts"
      ],
      "settings": {
        "foreground": "#ff8a3d"
      }
    },
    {
      "scope": [
        "meta.structure.dictionary.value.json string.quoted.double.json",
        "string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#ffdc8a"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss",
        "meta.property-name.css",
        "meta.property-name.scss"
      ],
      "settings": {
        "foreground": "#ff8a3d"
      }
    },
    {
      "scope": [
        "meta.property-value.css",
        "meta.property-value.scss",
        "support.constant.property-value.css",
        "support.constant.property-value.scss",
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#ffdc8a"
      }
    },
    {
      "scope": [
        "support.module",
        "support.type.object.module",
        "support.variable",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#ffd08a"
      }
    },
    {
      "scope": [
        "constant.other.symbol.ruby",
        "punctuation.definition.constant.ruby",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#ff8a3d"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.vue",
        "entity.other.attribute-name.jsx",
        "entity.other.attribute-name.tsx",
        "support.type.property-name.vue"
      ],
      "settings": {
        "foreground": "#ffdc8a"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#ff8a3d"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#fff8e8",
        "background": "#b83414"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#ffdc8a",
    "class": "#ffdc8a",
    "interface": "#ffdc8a",
    "enum": "#ffdc8a",
    "type": "#ffdc8a",
    "typeParameter": "#ffdc8a",
    "function": "#ffdc8a",
    "method": "#ffdc8a",
    "macro": "#ff8a3d",
    "variable": "#ffdc8a",
    "parameter": "#ffdc8a",
    "property": "#ffdc8a",
    "enumMember": "#ffdc8a",
    "event": "#ff8a3d",
    "operator": "#ff8a3d",
    "keyword": {
      "foreground": "#ff8a3d",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#f08b57",
      "fontStyle": "italic"
    },
    "string": "#ffdc8a",
    "number": "#ffdc8a",
    "regexp": "#ffdc8a",
    "decorator": "#ff8a3d"
  }
}

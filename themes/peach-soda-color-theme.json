  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#a87967",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#407f3f"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#c87511"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#d85f9f",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#c94f45"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#995fc9"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#4b2f25"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#a65f00"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#b65b34"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#d85f9f"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#b65b34"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#c94f45",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#a65f00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#995fc9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ffffff",
        "background": "#b3261e"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#995fc9",
    "class": "#995fc9",
    "interface": "#995fc9",
    "enum": "#c87511",
    "type": "#995fc9",
    "typeParameter": "#a65f00",
    "function": "#c94f45",
    "method": "#c94f45",
    "macro": "#c94f45",
    "variable": "#4b2f25",
    "parameter": "#a65f00",
    "property": "#b65b34",
    "enumMember": "#c87511",
    "event": "#d85f9f",
    "operator": "#c94f45",
    "keyword": {
      "foreground": "#d85f9f",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#a87967",
      "fontStyle": "italic"
    },
    "string": "#407f3f",
    "number": "#c87511",
    "regexp": "#995fc9",
    "decorator": "#d85f9f"
  }
}

    "panel.background": "#fff4cf",
    "panel.foreground": "#49340d",
    "panel.border": "#e6b94c",
    "panelTitle.activeForeground": "#49340d",
    "panelTitle.inactiveForeground": "#8a6b24",
    "panelTitle.activeBorder": "#c47f00",
    "terminal.background": "#fff9e6",
    "terminal.foreground": "#49340d",
    "terminal.ansiBlack": "#fff9e6",
    "terminal.ansiRed": "#b3261e",
    "terminal.ansiGreen": "#5b7f1f",
    "terminal.ansiYellow": "#b85400",
    "terminal.ansiBlue": "#8c5c00",
    "terminal.ansiMagenta": "#6f7f00",
    "terminal.ansiCyan": "#c47f00",
    "terminal.ansiWhite": "#49340d",
    "terminal.ansiBrightBlack": "#8a6b24",
    "terminal.ansiBrightRed": "#b3261e",
    "terminal.ansiBrightGreen": "#5b7f1f",
    "terminal.ansiBrightYellow": "#b85400",
    "terminal.ansiBrightBlue": "#8c5c00",
    "terminal.ansiBrightMagenta": "#6f7f00",
    "terminal.ansiBrightCyan": "#c47f00",
    "terminal.ansiBrightWhite": "#2b1b16",
    "input.background": "#fff9e6",
    "input.foreground": "#49340d",
    "input.border": "#e6b94c",
    "input.placeholderForeground": "#8a6b24",
    "inputOption.activeBackground": "#c47f0022",
    "inputOption.activeBorder": "#c47f00",
    "inputValidation.errorBackground": "#fff0bc",
    "inputValidation.errorBorder": "#b3261e",
    "inputValidation.warningBackground": "#fff0bc",
    "inputValidation.warningBorder": "#b85400",
    "inputValidation.infoBackground": "#fff0bc",
    "inputValidation.infoBorder": "#c47f00",
    "button.background": "#c47f00",
    "button.foreground": "#fff9e6",
    "button.hoverBackground": "#b85400",
    "button.secondaryBackground": "#ffe28a",
    "button.secondaryForeground": "#49340d",
    "button.secondaryHoverBackground": "#e6b94c",
    "dropdown.background": "#fff9e6",
    "dropdown.foreground": "#49340d",
    "dropdown.border": "#e6b94c",
    "list.activeSelectionBackground": "#ffe28a",
    "list.activeSelectionForeground": "#49340d",
    "list.inactiveSelectionBackground": "#fff0bc",
    "list.inactiveSelectionForeground": "#49340d",
    "list.hoverBackground": "#fff0bc",
    "list.highlightForeground": "#c47f00",
    "list.focusOutline": "#c47f00",
    "menu.background": "#fff4cf",
    "menu.foreground": "#49340d",
    "menu.selectionBackground": "#ffe28a",
    "menu.selectionForeground": "#49340d",
    "menu.separatorBackground": "#e6b94c",

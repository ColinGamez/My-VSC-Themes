    "scrollbarSlider.activeBackground": "#c47f0088",
    "editorOverviewRuler.border": "#fff9e6",
    "editorOverviewRuler.modifiedForeground": "#b85400",
    "editorOverviewRuler.addedForeground": "#5b7f1f",
    "editorOverviewRuler.deletedForeground": "#b3261e",

    "editorGutter.background": "#fff9e6",
    "editorGutter.modifiedBackground": "#b85400",
    "editorGutter.addedBackground": "#5b7f1f",
    "editorGutter.deletedBackground": "#b3261e",
    "minimap.background": "#fff9e6",
    "minimap.selectionHighlight": "#c47f0070",
    "minimap.findMatchHighlight": "#b85400",
    "minimap.errorHighlight": "#b3261e",
    "minimap.warningHighlight": "#b85400",
    "statusBar.background": "#ffe28a",
    "statusBar.foreground": "#49340d",
    "statusBar.border": "#e6b94c",
    "statusBar.debuggingBackground": "#c47f00",
    "statusBar.debuggingForeground": "#fff9e6",
    "statusBar.noFolderBackground": "#fff0bc",
    "statusBarItem.hoverBackground": "#e6b94c",
    "statusBarItem.remoteBackground": "#c47f00",
    "statusBarItem.remoteForeground": "#fff9e6",
    "titleBar.activeBackground": "#fff0bc",
    "titleBar.activeForeground": "#49340d",
    "titleBar.inactiveBackground": "#fff4cf",

    "editorOverviewRuler.warningForeground": "#b85400",
    "editorOverviewRuler.infoForeground": "#c47f00",
    "badge.background": "#c47f00",
    "badge.foreground": "#fff9e6",
    "progressBar.background": "#c47f00",
    "notificationCenter.border": "#e6b94c",
    "notificationCenterHeader.background": "#ffe28a",
    "notificationCenterHeader.foreground": "#49340d",
    "notifications.background": "#fff4cf",
    "notifications.foreground": "#49340d",
    "notifications.border": "#e6b94c",
    "notificationToast.border": "#e6b94c",
    "breadcrumb.background": "#fff9e6",
    "breadcrumb.foreground": "#8a6b24",
    "breadcrumb.focusForeground": "#49340d",
    "breadcrumb.activeSelectionForeground": "#c47f00",
    "gitDecoration.addedResourceForeground": "#5b7f1f",
    "gitDecoration.modifiedResourceForeground": "#b85400",
    "gitDecoration.deletedResourceForeground": "#b3261e",
    "gitDecoration.untrackedResourceForeground": "#5b7f1f",
    "gitDecoration.ignoredResourceForeground": "#8a6b24",
    "gitDecoration.conflictingResourceForeground": "#6f7f00",
    "diffEditor.insertedTextBackground": "#5b7f1f22",
    "diffEditor.removedTextBackground": "#b3261e22",
    "diffEditor.border": "#e6b94c",
    "peekView.border": "#c47f00",
    "peekViewEditor.background": "#fff9e6",
    "peekViewResult.background": "#fff4cf",
    "peekViewTitle.background": "#ffe28a",
    "peekViewTitleLabel.foreground": "#49340d",
    "peekViewTitleDescription.foreground": "#8a6b24"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9b7a37",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#5b7f1f"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#a56400"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#b85400",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#8c5c00"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#796600"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#49340d"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#b85400"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#945600"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#b85400"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#945600"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#c47f00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#b85400",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#796600",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ffffff",
        "background": "#b3261e"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#796600",
    "class": "#796600",
    "interface": "#796600",
    "enum": "#a56400",
    "type": "#796600",
    "typeParameter": "#b85400",
    "function": "#8c5c00",
    "method": "#8c5c00",
    "macro": "#c47f00",
    "variable": "#49340d",
    "parameter": "#b85400",
    "property": "#945600",
    "enumMember": "#a56400",
    "event": "#6f7f00",
    "operator": "#c47f00",
    "keyword": {
      "foreground": "#b85400",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#9b7a37",
      "fontStyle": "italic"
    },
    "string": "#5b7f1f",
    "number": "#a56400",
    "regexp": "#796600",
    "decorator": "#6f7f00"
  }
}

  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#a36685",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#ffb3c7"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffd166"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff4d8d",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#ff77aa"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#ffe6f2"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#ffd166"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#ffa3c4"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff4d8d"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ffa3c4"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#ff4d8d",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ffd166",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#c084fc",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#170713",
        "background": "#ff315d"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#c084fc",
    "class": "#c084fc",
    "interface": "#c084fc",
    "enum": "#ffd166",
    "type": "#c084fc",
    "typeParameter": "#ffd166",
    "function": "#ff77aa",
    "method": "#ff77aa",
    "macro": "#ff4d8d",
    "variable": "#ffe6f2",
    "parameter": "#ffd166",
    "property": "#ffa3c4",
    "enumMember": "#ffd166",
    "event": "#ffb3c7",
    "operator": "#ff4d8d",
    "keyword": {
      "foreground": "#ff4d8d",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#a36685",
      "fontStyle": "italic"
    },
    "string": "#ffb3c7",
    "number": "#ffd166",
    "regexp": "#c084fc",
    "decorator": "#ffb3c7"
  }
}

    "terminal.ansiBrightRed": "#ff4d6d",
    "terminal.ansiBrightGreen": "#79f2c0",
    "terminal.ansiBrightYellow": "#8bd3ff",
    "terminal.ansiBrightBlue": "#44c7ff",
    "terminal.ansiBrightMagenta": "#ff3d81",
    "terminal.ansiBrightCyan": "#00b7ff",
    "terminal.ansiBrightWhite": "#ffffff",
    "input.background": "#06111f",
    "input.foreground": "#dff6ff",
    "input.border": "#1d527a",
    "input.placeholderForeground": "#7197b5",
    "inputOption.activeBackground": "#00b7ff22",
    "inputOption.activeBorder": "#00b7ff",
    "inputValidation.errorBackground": "#0a1b30",
    "inputValidation.errorBorder": "#ff4d6d",
    "inputValidation.warningBackground": "#0a1b30",
    "inputValidation.warningBorder": "#8bd3ff",
    "inputValidation.infoBackground": "#0a1b30",
    "inputValidation.infoBorder": "#00b7ff",
    "button.background": "#00b7ff",
    "button.foreground": "#06111f",

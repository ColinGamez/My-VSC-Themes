    "badge.foreground": "#06111f",
    "progressBar.background": "#00b7ff",
    "notificationCenter.border": "#1d527a",
    "notificationCenterHeader.background": "#123052",
    "notificationCenterHeader.foreground": "#dff6ff",
    "notifications.background": "#081728",
    "notifications.foreground": "#dff6ff",
    "notifications.border": "#1d527a",
    "notificationToast.border": "#1d527a",
    "breadcrumb.background": "#06111f",
    "breadcrumb.foreground": "#7197b5",
    "breadcrumb.focusForeground": "#dff6ff",
    "breadcrumb.activeSelectionForeground": "#00b7ff",
    "gitDecoration.addedResourceForeground": "#79f2c0",
    "gitDecoration.modifiedResourceForeground": "#8bd3ff",
    "gitDecoration.deletedResourceForeground": "#ff4d6d",
    "gitDecoration.untrackedResourceForeground": "#79f2c0",
    "gitDecoration.ignoredResourceForeground": "#7197b5",
    "gitDecoration.conflictingResourceForeground": "#ff3d81",
    "diffEditor.insertedTextBackground": "#79f2c022",
    "diffEditor.removedTextBackground": "#ff4d6d22",
    "diffEditor.border": "#1d527a",
    "peekView.border": "#00b7ff",
    "peekViewEditor.background": "#06111f",
    "peekViewResult.background": "#081728",
    "peekViewTitle.background": "#123052",
    "peekViewTitleLabel.foreground": "#dff6ff",
    "peekViewTitleDescription.foreground": "#7197b5"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6b8098",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#79f2c0"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffcd6b"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff3d81",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#44c7ff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#8ea7ff"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#dff6ff"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#8bd3ff"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#feb2d0"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff3d81"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#feb2d0"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#00b7ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#8bd3ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#8ea7ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#06111f",
        "background": "#ff4d6d"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#8ea7ff",
    "class": "#8ea7ff",
    "interface": "#8ea7ff",
    "enum": "#ffcd6b",
    "type": "#8ea7ff",
    "typeParameter": "#8bd3ff",
    "function": "#44c7ff",
    "method": "#44c7ff",
    "macro": "#00b7ff",
    "variable": "#dff6ff",
    "parameter": "#8bd3ff",
    "property": "#feb2d0",
    "enumMember": "#ffcd6b",
    "event": "#ff3d81",
    "operator": "#00b7ff",
    "keyword": {
      "foreground": "#ff3d81",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#6b8098",
      "fontStyle": "italic"
    },
    "string": "#79f2c0",
    "number": "#ffcd6b",
    "regexp": "#8ea7ff",
    "decorator": "#ff3d81"
  }
}

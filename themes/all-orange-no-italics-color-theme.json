    "peekViewEditor.background": "#160804",
    "peekViewResult.background": "#241007",
    "peekViewTitle.background": "#331506",
    "peekViewTitleLabel.foreground": "#ffd08a",
    "peekViewTitleDescription.foreground": "#a36845"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#a36845"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#ffd36f"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffbc42"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#fa824c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#ffbf69"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#ffbf69"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#ffbf69"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#ffcb92"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#ffbf6b"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#fa824c"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ffbc42"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#ffb35c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ffd36f",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#ffbf69"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#fff0d0",
        "background": "#b73310"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#ffbf69",
    "class": "#ffbf69",
    "interface": "#ffd36f",
    "enum": "#ffbc42",
    "type": "#ffbf69",
    "typeParameter": "#ffcb92",
    "function": "#ffbf69",
    "method": "#ffbf69",
    "macro": "#fa824c",
    "variable": "#ffbf69",
    "parameter": "#ffcb92",
    "property": "#ffbf6b",
    "enumMember": "#ffbc42",
    "event": "#fa824c",
    "operator": "#fa824c",
    "keyword": {
      "foreground": "#fa824c",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#a36845"
    },
    "string": "#ffd36f",
    "number": "#ffbc42",
    "regexp": "#ffbf69",
    "decorator": "#fa824c"
  }
}

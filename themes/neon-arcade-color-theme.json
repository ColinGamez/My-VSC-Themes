  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6570ad",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#8cffc1"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffd166"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff4fd8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#00d7ff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#b891ff"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#e8edff"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#ffd166"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#f7a8ff"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff4fd8"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f7a8ff"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#00d7ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ffd166",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#b891ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#07091f",
        "background": "#ff5f7a"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#b891ff",
    "class": "#b891ff",
    "interface": "#b891ff",
    "enum": "#ffd166",
    "type": "#b891ff",
    "typeParameter": "#ffd166",
    "function": "#00d7ff",
    "method": "#00d7ff",
    "macro": "#00d7ff",
    "variable": "#e8edff",
    "parameter": "#ffd166",
    "property": "#f7a8ff",
    "enumMember": "#ffd166",
    "event": "#ff4fd8",
    "operator": "#00d7ff",
    "keyword": {
      "foreground": "#ff4fd8",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#6570ad",
      "fontStyle": "italic"
    },
    "string": "#8cffc1",
    "number": "#ffd166",
    "regexp": "#b891ff",
    "decorator": "#ff4fd8"
  }
}

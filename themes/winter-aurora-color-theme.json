  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6b93a8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#a7f3d0"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#c4b5fd"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#93c5fd",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#67e8f9"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#c4b5fd"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#e8fbff"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#bff7e8"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#99f6e4"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#93c5fd"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#99f6e4"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#7dd3fc",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#bff7e8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#c4b5fd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#06111f",
        "background": "#f87171"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#c4b5fd",
    "class": "#c4b5fd",
    "interface": "#c4b5fd",
    "enum": "#c4b5fd",
    "type": "#c4b5fd",
    "typeParameter": "#bff7e8",
    "function": "#67e8f9",
    "method": "#67e8f9",
    "macro": "#7dd3fc",
    "variable": "#e8fbff",
    "parameter": "#bff7e8",
    "property": "#99f6e4",
    "enumMember": "#c4b5fd",
    "event": "#a78bfa",
    "operator": "#7dd3fc",
    "keyword": {
      "foreground": "#93c5fd",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#6b93a8",
      "fontStyle": "italic"
    },
    "string": "#a7f3d0",
    "number": "#c4b5fd",
    "regexp": "#c4b5fd",
    "decorator": "#a78bfa"
  }
}

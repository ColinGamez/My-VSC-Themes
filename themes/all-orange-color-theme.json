  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#c87548",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#ffbf69"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffbf69"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#fa824c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#ffbf69"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#ffbf69"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#ffbf69"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#ffbf69"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#ffbf69"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#fa824c"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ffbf69"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#fa824c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ffbf69",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#ffbf69",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ffedcf",
        "background": "#8f2d13"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#ffbf69",
    "class": "#ffbf69",
    "interface": "#ffbf69",
    "enum": "#ffbf69",
    "type": "#ffbf69",
    "typeParameter": "#ffbf69",
    "function": "#ffbf69",
    "method": "#ffbf69",
    "macro": "#fa824c",
    "variable": "#ffbf69",
    "parameter": "#ffbf69",
    "property": "#ffbf69",
    "enumMember": "#ffbf69",
    "event": "#fa824c",
    "operator": "#fa824c",
    "keyword": {
      "foreground": "#fa824c",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#c87548",
      "fontStyle": "italic"
    },
    "string": "#ffbf69",
    "number": "#ffbf69",
    "regexp": "#ffbf69",
    "decorator": "#fa824c"
  }
}

  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#aa6f5a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#7ee2a8"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffd166"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff6b35",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#4cc9f0"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#f9c74f"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#ffe7b8"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#ffd166"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#ffb86b"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff6b35"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ffb86b"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#ff9f1c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ffd166",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#f9c74f",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#170b12",
        "background": "#ff3d4f"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#f9c74f",
    "class": "#f9c74f",
    "interface": "#f9c74f",
    "enum": "#ffd166",
    "type": "#f9c74f",
    "typeParameter": "#ffd166",
    "function": "#4cc9f0",
    "method": "#4cc9f0",
    "macro": "#ff9f1c",
    "variable": "#ffe7b8",
    "parameter": "#ffd166",
    "property": "#ffb86b",
    "enumMember": "#ffd166",
    "event": "#ff4d6d",
    "operator": "#ff9f1c",
    "keyword": {
      "foreground": "#ff6b35",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#aa6f5a",
      "fontStyle": "italic"
    },
    "string": "#7ee2a8",
    "number": "#ffd166",
    "regexp": "#f9c74f",
    "decorator": "#ff4d6d"
  }
}

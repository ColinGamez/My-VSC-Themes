  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#765d9a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#7cfca4"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#f9f871"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff2a6d",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#00f5d4"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#9b5cff"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#f6eaff"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#f9f871"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#ff7ab6"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff2a6d"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ff7ab6"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#00f5d4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#f9f871",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#9b5cff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#08040f",
        "background": "#ff3864"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#9b5cff",
    "class": "#9b5cff",
    "interface": "#9b5cff",
    "enum": "#f9f871",
    "type": "#9b5cff",
    "typeParameter": "#f9f871",
    "function": "#00f5d4",
    "method": "#00f5d4",
    "macro": "#00f5d4",
    "variable": "#f6eaff",
    "parameter": "#f9f871",
    "property": "#ff7ab6",
    "enumMember": "#f9f871",
    "event": "#ff2a6d",
    "operator": "#00f5d4",
    "keyword": {
      "foreground": "#ff2a6d",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#765d9a",
      "fontStyle": "italic"
    },
    "string": "#7cfca4",
    "number": "#f9f871",
    "regexp": "#9b5cff",
    "decorator": "#ff2a6d"
  }
}

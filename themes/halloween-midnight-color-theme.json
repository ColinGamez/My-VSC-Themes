  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8d6798",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#c6ff4d"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffbd4a"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff8a00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#b967ff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#f7a8ff"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#f4e6ff"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#c6ff4d"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#ffa94d"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff8a00"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ffa94d"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#ff8a00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#c6ff4d",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#f7a8ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#0f0715",
        "background": "#ff4d5e"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#f7a8ff",
    "class": "#f7a8ff",
    "interface": "#f7a8ff",
    "enum": "#ffbd4a",
    "type": "#f7a8ff",
    "typeParameter": "#c6ff4d",
    "function": "#b967ff",
    "method": "#b967ff",
    "macro": "#ff8a00",
    "variable": "#f4e6ff",
    "parameter": "#c6ff4d",
    "property": "#ffa94d",
    "enumMember": "#ffbd4a",
    "event": "#b967ff",
    "operator": "#ff8a00",
    "keyword": {
      "foreground": "#ff8a00",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#8d6798",
      "fontStyle": "italic"
    },
    "string": "#c6ff4d",
    "number": "#ffbd4a",
    "regexp": "#f7a8ff",
    "decorator": "#b967ff"
  }
}

    "breadcrumb.foreground": "#7ea774",
    "breadcrumb.focusForeground": "#d9f5c9",
    "breadcrumb.activeSelectionForeground": "#a8d45b",
    "gitDecoration.addedResourceForeground": "#5ee39a",
    "gitDecoration.modifiedResourceForeground": "#f4d35e",
    "gitDecoration.deletedResourceForeground": "#ff8066",
    "gitDecoration.untrackedResourceForeground": "#5ee39a",
    "gitDecoration.ignoredResourceForeground": "#7ea774",
    "gitDecoration.conflictingResourceForeground": "#5ee39a",
    "diffEditor.insertedTextBackground": "#5ee39a22",
    "diffEditor.removedTextBackground": "#ff806622",
    "diffEditor.border": "#28583a",
    "peekView.border": "#a8d45b",
    "peekViewEditor.background": "#07130d",
    "peekViewResult.background": "#0a1a11",
    "peekViewTitle.background": "#14321f",
    "peekViewTitleLabel.foreground": "#d9f5c9",
    "peekViewTitleDescription.foreground": "#7ea774"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6f9469",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#b7e86b"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#f4d35e"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#a8d45b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#5ee39a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#d7ef8f"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#d9f5c9"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#f4d35e"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#c3e57d"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#a8d45b"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c3e57d"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#a8d45b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#f4d35e",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#d7ef8f",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#07130d",
        "background": "#ff8066"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#d7ef8f",
    "class": "#d7ef8f",
    "interface": "#d7ef8f",
    "enum": "#f4d35e",
    "type": "#d7ef8f",
    "typeParameter": "#f4d35e",
    "function": "#5ee39a",
    "method": "#5ee39a",
    "macro": "#a8d45b",
    "variable": "#d9f5c9",
    "parameter": "#f4d35e",
    "property": "#c3e57d",
    "enumMember": "#f4d35e",
    "event": "#5ee39a",
    "operator": "#a8d45b",
    "keyword": {
      "foreground": "#a8d45b",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#6f9469",
      "fontStyle": "italic"
    },
    "string": "#b7e86b",
    "number": "#f4d35e",
    "regexp": "#d7ef8f",
    "decorator": "#5ee39a"
  }
}

    "terminal.ansiBrightGreen": "#5ee39a",
    "terminal.ansiBrightYellow": "#f4d35e",
    "terminal.ansiBrightBlue": "#5ee39a",
    "terminal.ansiBrightMagenta": "#5ee39a",
    "terminal.ansiBrightCyan": "#a8d45b",
    "terminal.ansiBrightWhite": "#ffffff",
    "input.background": "#07130d",
    "input.foreground": "#d9f5c9",
    "input.border": "#28583a",
    "input.placeholderForeground": "#7ea774",
    "inputOption.activeBackground": "#a8d45b22",
    "inputOption.activeBorder": "#a8d45b",
    "inputValidation.errorBackground": "#0c1d13",
    "inputValidation.errorBorder": "#ff8066",
    "inputValidation.warningBackground": "#0c1d13",
    "inputValidation.warningBorder": "#f4d35e",
    "inputValidation.infoBackground": "#0c1d13",
    "inputValidation.infoBorder": "#a8d45b",
    "button.background": "#a8d45b",

  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6f8e66",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#a3d977"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#f4d35e"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7cb342",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#4db6ac"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#b0bec5"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#e6f5d6"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#f4d35e"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#c49a6c"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7cb342"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c49a6c"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#7cb342",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#f4d35e",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#b0bec5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#09140b",
        "background": "#ef5350"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#b0bec5",
    "class": "#b0bec5",
    "interface": "#b0bec5",
    "enum": "#f4d35e",
    "type": "#b0bec5",
    "typeParameter": "#f4d35e",
    "function": "#4db6ac",
    "method": "#4db6ac",
    "macro": "#7cb342",
    "variable": "#e6f5d6",
    "parameter": "#f4d35e",
    "property": "#c49a6c",
    "enumMember": "#f4d35e",
    "event": "#8d6e63",
    "operator": "#7cb342",
    "keyword": {
      "foreground": "#7cb342",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#6f8e66",
      "fontStyle": "italic"
    },
    "string": "#a3d977",
    "number": "#f4d35e",
    "regexp": "#b0bec5",
    "decorator": "#8d6e63"
  }
}

  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6f78a8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#86efac"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#facc15"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#f472b6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#eef2ff"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#f472b6"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#fde68a"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#f472b6"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#fde68a"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#facc15",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#f472b6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#a78bfa",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#060711",
        "background": "#fb7185"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#a78bfa",
    "class": "#a78bfa",
    "interface": "#a78bfa",
    "enum": "#facc15",
    "type": "#a78bfa",
    "typeParameter": "#f472b6",
    "function": "#22d3ee",
    "method": "#22d3ee",
    "macro": "#facc15",
    "variable": "#eef2ff",
    "parameter": "#f472b6",
    "property": "#fde68a",
    "enumMember": "#facc15",
    "event": "#22d3ee",
    "operator": "#facc15",
    "keyword": {
      "foreground": "#f472b6",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#6f78a8",
      "fontStyle": "italic"
    },
    "string": "#86efac",
    "number": "#facc15",
    "regexp": "#a78bfa",
    "decorator": "#22d3ee"
  }
}

    "panelTitle.activeBorder": "#7dd3fc",
    "terminal.background": "#101114",
    "terminal.foreground": "#f1f3f5",
    "terminal.ansiBlack": "#101114",
    "terminal.ansiRed": "#fb7185",
    "terminal.ansiGreen": "#86efac",
    "terminal.ansiYellow": "#facc15",

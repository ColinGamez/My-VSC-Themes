    "terminal.ansiBrightBlack": "#8d96a3",
    "terminal.ansiBrightRed": "#fb7185",
    "terminal.ansiBrightGreen": "#86efac",
    "terminal.ansiBrightYellow": "#facc15",
    "terminal.ansiBrightBlue": "#7dd3fc",
    "terminal.ansiBrightMagenta": "#f472b6",
    "terminal.ansiBrightCyan": "#7dd3fc",
    "terminal.ansiBrightWhite": "#ffffff",
    "input.background": "#101114",
    "input.foreground": "#f1f3f5",
    "input.border": "#3a3f4a",
    "input.placeholderForeground": "#8d96a3",
    "inputOption.activeBackground": "#7dd3fc22",
    "inputOption.activeBorder": "#7dd3fc",
    "inputValidation.errorBackground": "#17191e",
    "inputValidation.errorBorder": "#fb7185",
    "inputValidation.warningBackground": "#17191e",
    "inputValidation.warningBorder": "#facc15",
    "inputValidation.infoBackground": "#17191e",
    "inputValidation.infoBorder": "#7dd3fc",
    "button.background": "#7dd3fc",
    "button.foreground": "#101114",
    "button.hoverBackground": "#facc15",
    "button.secondaryBackground": "#252832",
    "button.secondaryForeground": "#f1f3f5",
    "button.secondaryHoverBackground": "#3a3f4a",
    "dropdown.background": "#101114",
    "dropdown.foreground": "#f1f3f5",
    "dropdown.border": "#3a3f4a",

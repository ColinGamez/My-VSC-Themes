    "editorGutter.addedBackground": "#86efac",
    "editorGutter.deletedBackground": "#fb7185",
    "minimap.background": "#101114",
    "minimap.selectionHighlight": "#7dd3fc70",
    "minimap.findMatchHighlight": "#facc15",
    "minimap.errorHighlight": "#fb7185",
    "minimap.warningHighlight": "#facc15",
    "statusBar.background": "#252832",
    "statusBar.foreground": "#f1f3f5",
    "statusBar.border": "#3a3f4a",
    "statusBar.debuggingBackground": "#7dd3fc",

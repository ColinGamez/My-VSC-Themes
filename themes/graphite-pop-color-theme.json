    "editorOverviewRuler.warningForeground": "#facc15",
    "editorOverviewRuler.infoForeground": "#7dd3fc",
    "badge.background": "#7dd3fc",
    "badge.foreground": "#101114",
    "progressBar.background": "#7dd3fc",
    "notificationCenter.border": "#3a3f4a",
    "notificationCenterHeader.background": "#252832",
    "notificationCenterHeader.foreground": "#f1f3f5",
    "notifications.background": "#13151a",
    "notifications.foreground": "#f1f3f5",
    "notifications.border": "#3a3f4a",
    "notificationToast.border": "#3a3f4a",
    "breadcrumb.background": "#101114",
    "breadcrumb.foreground": "#8d96a3",
    "breadcrumb.focusForeground": "#f1f3f5",
    "breadcrumb.activeSelectionForeground": "#7dd3fc",
    "gitDecoration.addedResourceForeground": "#86efac",
    "gitDecoration.modifiedResourceForeground": "#facc15",
    "gitDecoration.deletedResourceForeground": "#fb7185",
    "gitDecoration.untrackedResourceForeground": "#86efac",
    "gitDecoration.ignoredResourceForeground": "#8d96a3",
    "gitDecoration.conflictingResourceForeground": "#f472b6",
    "diffEditor.insertedTextBackground": "#86efac22",
    "diffEditor.removedTextBackground": "#fb718522",
    "diffEditor.border": "#3a3f4a",
    "peekView.border": "#7dd3fc",
    "peekViewEditor.background": "#101114",
    "peekViewResult.background": "#13151a",
    "peekViewTitle.background": "#252832",
    "peekViewTitleLabel.foreground": "#f1f3f5",
    "peekViewTitleDescription.foreground": "#8d96a3"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#737b87",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#86efac"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#facc15"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#f472b6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#7dd3fc"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#c4b5fd"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#f1f3f5"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#facc15"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#f0abfc"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#f472b6"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f0abfc"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#7dd3fc",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#facc15",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#c4b5fd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#101114",
        "background": "#fb7185"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#c4b5fd",
    "class": "#c4b5fd",
    "interface": "#c4b5fd",
    "enum": "#facc15",
    "type": "#c4b5fd",
    "typeParameter": "#facc15",
    "function": "#7dd3fc",
    "method": "#7dd3fc",
    "macro": "#7dd3fc",
    "variable": "#f1f3f5",
    "parameter": "#facc15",
    "property": "#f0abfc",
    "enumMember": "#facc15",
    "event": "#f472b6",
    "operator": "#7dd3fc",
    "keyword": {
      "foreground": "#f472b6",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#737b87",
      "fontStyle": "italic"
    },
    "string": "#86efac",
    "number": "#facc15",
    "regexp": "#c4b5fd",
    "decorator": "#f472b6"
  }
}

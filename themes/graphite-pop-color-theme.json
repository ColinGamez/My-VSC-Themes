    "list.activeSelectionForeground": "#f1f3f5",
    "list.inactiveSelectionBackground": "#17191e",
    "list.inactiveSelectionForeground": "#f1f3f5",
    "list.hoverBackground": "#17191e",
    "list.highlightForeground": "#7dd3fc",
    "list.focusOutline": "#7dd3fc",
    "menu.background": "#13151a",
    "menu.foreground": "#f1f3f5",

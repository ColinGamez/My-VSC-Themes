  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5d9b65",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#39ff14"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffd60a"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7cff6b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#00bbf9"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#caffbf"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#d7ffd9"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#00bbf9"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#9bf6ff"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7cff6b"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#9bf6ff"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#39ff14",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#00bbf9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#caffbf",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#07120b",
        "background": "#ff5a5f"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#caffbf",
    "class": "#caffbf",
    "interface": "#caffbf",
    "enum": "#ffd60a",
    "type": "#caffbf",
    "typeParameter": "#00bbf9",
    "function": "#00bbf9",
    "method": "#00bbf9",
    "macro": "#39ff14",
    "variable": "#d7ffd9",
    "parameter": "#00bbf9",
    "property": "#9bf6ff",
    "enumMember": "#ffd60a",
    "event": "#ffd60a",
    "operator": "#39ff14",
    "keyword": {
      "foreground": "#7cff6b",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#5d9b65",
      "fontStyle": "italic"
    },
    "string": "#39ff14",
    "number": "#ffd60a",
    "regexp": "#caffbf",
    "decorator": "#ffd60a"
  }
}

    "symbolIcon.classForeground": "#9cc9ff",
    "symbolIcon.functionForeground": "#66b7ff",
    "symbolIcon.methodForeground": "#66b7ff",
    "symbolIcon.variableForeground": "#e4f0ff",
    "symbolIcon.propertyForeground": "#89d67f"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6b88a8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#6bd45a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffd45c"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#2f8cff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#66b7ff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#9cc9ff"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#e4f0ff"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#ffd45c"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#89d67f"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#2f8cff"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#89d67f"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#2f8cff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ffd45c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#9cc9ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#08111f",
        "background": "#ff6464"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#9cc9ff",
    "class": "#9cc9ff",
    "interface": "#9cc9ff",
    "enum": "#ffd45c",
    "type": "#9cc9ff",
    "typeParameter": "#ffd45c",
    "function": "#66b7ff",
    "method": "#66b7ff",
    "macro": "#2f8cff",
    "variable": "#e4f0ff",
    "parameter": "#ffd45c",
    "property": "#89d67f",
    "enumMember": "#ffd45c",
    "event": "#6bd45a",
    "operator": "#2f8cff",
    "keyword": {
      "foreground": "#2f8cff",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#6b88a8",
      "fontStyle": "italic"
    },
    "string": "#6bd45a",
    "number": "#ffd45c",
    "regexp": "#9cc9ff",
    "decorator": "#6bd45a"
  }
}

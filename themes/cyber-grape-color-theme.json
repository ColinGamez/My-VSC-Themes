  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8a66a8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#ccff33"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffcf5a"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#bd5bff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#ff7ad9"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#7df9ff"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#f4e8ff"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#ff7ad9"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#d8a8ff"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#bd5bff"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#d8a8ff"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#bd5bff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ff7ad9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#7df9ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#10041c",
        "background": "#ff4f8b"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#7df9ff",
    "class": "#7df9ff",
    "interface": "#7df9ff",
    "enum": "#ffcf5a",
    "type": "#7df9ff",
    "typeParameter": "#ff7ad9",
    "function": "#ff7ad9",
    "method": "#ff7ad9",
    "macro": "#bd5bff",
    "variable": "#f4e8ff",
    "parameter": "#ff7ad9",
    "property": "#d8a8ff",
    "enumMember": "#ffcf5a",
    "event": "#ccff33",
    "operator": "#bd5bff",
    "keyword": {
      "foreground": "#bd5bff",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#8a66a8",
      "fontStyle": "italic"
    },
    "string": "#ccff33",
    "number": "#ffcf5a",
    "regexp": "#7df9ff",
    "decorator": "#ccff33"
  }
}

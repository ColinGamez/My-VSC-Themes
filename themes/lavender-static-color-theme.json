  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8372ad",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#a7f3d0"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffd6f6"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#b891ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#6ee7ff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#ff8fe5"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#ede7ff"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#ffd6f6"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#d6c7ff"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#b891ff"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#d6c7ff"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#b891ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ffd6f6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#ff8fe5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#0d0a1f",
        "background": "#ff6b9a"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#ff8fe5",
    "class": "#ff8fe5",
    "interface": "#ff8fe5",
    "enum": "#ffd6f6",
    "type": "#ff8fe5",
    "typeParameter": "#ffd6f6",
    "function": "#6ee7ff",
    "method": "#6ee7ff",
    "macro": "#b891ff",
    "variable": "#ede7ff",
    "parameter": "#ffd6f6",
    "property": "#d6c7ff",
    "enumMember": "#ffd6f6",
    "event": "#6ee7ff",
    "operator": "#b891ff",
    "keyword": {
      "foreground": "#b891ff",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#8372ad",
      "fontStyle": "italic"
    },
    "string": "#a7f3d0",
    "number": "#ffd6f6",
    "regexp": "#ff8fe5",
    "decorator": "#6ee7ff"
  }
}

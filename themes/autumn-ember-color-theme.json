  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8f6236",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#a3c76d"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ef4444",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#f59e0b"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#eab308"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#f5d6a3"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#fb923c"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ef4444"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#fb923c"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#d97706",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#eab308",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#120a04",
        "background": "#dc2626"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#eab308",
    "class": "#eab308",
    "interface": "#eab308",
    "enum": "#fbbf24",
    "type": "#eab308",
    "typeParameter": "#fbbf24",
    "function": "#f59e0b",
    "method": "#f59e0b",
    "macro": "#d97706",
    "variable": "#f5d6a3",
    "parameter": "#fbbf24",
    "property": "#fb923c",
    "enumMember": "#fbbf24",
    "event": "#ef4444",
    "operator": "#d97706",
    "keyword": {
      "foreground": "#ef4444",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#8f6236",
      "fontStyle": "italic"
    },
    "string": "#a3c76d",
    "number": "#fbbf24",
    "regexp": "#eab308",
    "decorator": "#ef4444"
  }
}

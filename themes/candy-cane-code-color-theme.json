  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9b6b6f",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#008f5f"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#9a6a00"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#d62828",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#0f8b8d"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#5b5bd6"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#351819"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#9a6a00"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#b23a48"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#d62828"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#b23a48"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#d62828",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#9a6a00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#5b5bd6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ffffff",
        "background": "#b00020"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#5b5bd6",
    "class": "#5b5bd6",
    "interface": "#5b5bd6",
    "enum": "#9a6a00",
    "type": "#5b5bd6",
    "typeParameter": "#9a6a00",
    "function": "#0f8b8d",
    "method": "#0f8b8d",
    "macro": "#d62828",
    "variable": "#351819",
    "parameter": "#9a6a00",
    "property": "#b23a48",
    "enumMember": "#9a6a00",
    "event": "#008f5f",
    "operator": "#d62828",
    "keyword": {
      "foreground": "#d62828",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#9b6b6f",
      "fontStyle": "italic"
    },
    "string": "#008f5f",
    "number": "#9a6a00",
    "regexp": "#5b5bd6",
    "decorator": "#008f5f"
  }
}

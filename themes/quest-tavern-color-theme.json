  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8d6a3e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#b5c86b"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#e0b15c"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#d99a2b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#c08457"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#d6a96c"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#f4dfb4"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#c08457"
      }
    },
    {
      "scope": [
        "property",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#f1b56a"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#d99a2b"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f1b56a"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#d99a2b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#c08457",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#d6a96c",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#120b06",
        "background": "#d45d45"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#d6a96c",
    "class": "#d6a96c",
    "interface": "#d6a96c",
    "enum": "#e0b15c",
    "type": "#d6a96c",
    "typeParameter": "#c08457",
    "function": "#c08457",
    "method": "#c08457",
    "macro": "#d99a2b",
    "variable": "#f4dfb4",
    "parameter": "#c08457",
    "property": "#f1b56a",
    "enumMember": "#e0b15c",
    "event": "#7fb069",
    "operator": "#d99a2b",
    "keyword": {
      "foreground": "#d99a2b",
      "fontStyle": "bold"
    },
    "comment": {
      "foreground": "#8d6a3e",
      "fontStyle": "italic"
    },
    "string": "#b5c86b",
    "number": "#e0b15c",
    "regexp": "#d6a96c",
    "decorator": "#7fb069"
  }
}
